# Symbiont — example environment configuration
# Copy to .env and fill in your values.

# ── Server ──────────────────────────────────────────────────────────────────
SERVER_PORT=8080
SERVER_HOST=0.0.0.0
SERVER_ENV=development        # development | production

# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://symbiont:symbiont@localhost:5432/symbiont?sslmode=disable

# ── Security ────────────────────────────────────────────────────────────────
# Used to sign internal JWTs — generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-32-byte-secret

# ── Model providers ─────────────────────────────────────────────────────────
# Default provider: anthropic | openai | openrouter | ollama
DEFAULT_PROVIDER=anthropic

ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
OPENROUTER_API_KEY=sk-or-...

# Ollama (local models)
OLLAMA_BASE_URL=http://localhost:11434

# ── Default budgets (USD) ────────────────────────────────────────────────────
DEFAULT_AGENT_BUDGET_USD=5.00
DEFAULT_PROJECT_BUDGET_USD=100.00

# ── Object storage ──────────────────────────────────────────────────────────
# Use "local" for filesystem or "s3" for S3-compatible storage
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./data/blobs
# STORAGE_S3_BUCKET=symbiont-blobs
# STORAGE_S3_REGION=us-east-1

# ── Telemetry ───────────────────────────────────────────────────────────────
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# ── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=debug   # debug | info | warn | error
LOG_FORMAT=pretty  # pretty | json
